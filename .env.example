# ── SDOH Data Providers ──────────────────────────────────────
# SDOH_PROVIDER: mock | census | composite | local_db
#   mock      = hardcoded test data (no API keys needed)
#   census    = Census ACS only (education, housing, transportation)
#   composite = Census + AirNow + FoodCrime + CHAS (all sources merged)
#   local_db  = reads from data/sdoh.db (offline, HIPAA-safe)
SDOH_PROVIDER=composite

# Census ACS 5-Year API (free key)
# Get one at: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=*** EPA AirNow API (free key, for real-time air quality)
# Get one at: https://docs.airnowapi.org/airnow/downloads/
AIRNOW_API_KEY=*** USPS ZIP Code Crosswalk API + CHAS Housing (free token)
# Get one at: https://www.huduser.gov/hudapi/public/register
# One token works for: USPS Crosswalk, CHAS, FMR, Income Limits
HUD_API_TOKEN=*** ── LLM Provider ─────────────────────────────────────────────
# LLM_PROVIDER: mock | ollama
#   mock   = deterministic test care plans (no LLM needed)
#   ollama = local LLM via Ollama (requires Ollama running with model pulled)
LLM_PROVIDER=ollama
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_HOST=http://localhost:11434

# ── Application ──────────────────────────────────────────────
APP_TITLE=Pop-Health Intelligence Engine

# ── FBI Crime Data (optional, currently decommissioned) ─────
# The FBI CDE API has been decommissioned. The key is valid for
# other api.data.gov datasets. Crime data comes from County
# Health Rankings (embedded in the code) instead.
# FBI_API_KEY=