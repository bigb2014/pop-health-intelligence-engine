# LLM Provider Configuration
# ── SDOH Data Providers ──────────────────────────────────────
# SDOH_PROVIDER: mock | census | composite | local_db
SDOH_PROVIDER=mock

# Census ACS 5-Year API (free key)
# Get one at: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# EPA AirNow API (free key, optional — for real-time air quality)
# Get one at: https://docs.airnowapi.org/airnow/downloads/
AIRNOW_API_KEY=

# ── LLM Provider ─────────────────────────────────────────────
# LLM_PROVIDER: mock | llama
LLM_PROVIDER=mock
LLM_API_KEY=

# ── Application ──────────────────────────────────────────────
APP_TITLE=Pop-Health Intelligence Engine